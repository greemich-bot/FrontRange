{# adapted from starter code #}
{% extends "main.j2" %}
{% block content %}

<h1>Rental Inventory</h1>

{# READ table #}
<table>
    <thead>
        {# For the table header row, we print the DB attribute names #}
        <tr>
            <th>RentalID</th>
            <th>Type</th>
            <th>Delete</th>
        </tr>
    </thead>

    <tbody>
        {# For each row, print the id, fname, lname, homeworld and age #}
        {% for item in rentalinventory %}
        <tr>
            <td>{{ item.RentalID }}</td>
            <td>{{ item.Type }}</td>

            {# DELETE form #}
            <form id="delete_rental_form" method="POST" action="/rentalinventory/delete">
                <input type="hidden" name="delete_rental_id" value="{{ item.RentalID }}">
                <input type="hidden" name="delete_rental_name" value="{{ item.Type }}">
                <td>
                    <button type="submit" onclick="return confirm('Are you sure you want to delete this rental item: {{ item.Type }}? All assosciated rental records will also be deleted.')">
                        Delete
                    </button>
                </td>
            </form>
            
        </tr>
        {% endfor %}
    </tbody>
</table>

<h2>Add New Rental Item</h2>
<form class="cuForm" id="create_rental_form" method="POST" action="/rentalinventory/create">
    <label for="rental_type">Type:</label>
    <input type="text" id="rental_type" name="create_rental_type" required>
    <button type="submit">Add</button>
</form>


{% endblock %}