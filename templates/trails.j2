{# adapted from starter code, but customized buttons based on gemini's solution for the lifts table #}
{% extends "main.j2" %}
{% block content %}

<h1>Trails</h1>

{# READ table #}
<table>
    <thead>
        {# For the table header row, we print the DB attribute names #}
        <tr>
            <th>TrailID</th>
            <th>Trail Name</th>
            <th>Difficulty</th>
            <th>Trail Length</th>
            <th>Status</th>
            <th>Update Trail Status</th>
        </tr>
    </thead>

    <tbody>
        {# For each row, print the id, fname, lname, homeworld and age #}
        {% for trail in trails %}
        <tr>
            <td>{{ trail.TrailID }}</td>
            <td>{{ trail.TrailName}}</td>
            <td>{{ trail.Difficulty }}</td>
            <td>{{ trail.TrailLength }}</td>
            <td>
    {% if trail.Status == 1 %}
        <span style="color: #2e7d32; font-weight: bold;">Open</span>
    {% else %}
        <span style="color: #c62828; font-weight: bold;">Closed</span>
    {% endif %}
            <td>
    <form method="POST" action="/trails/update">
        <input type="hidden" name="update_trail_id" value="{{ trail.TrailID }}">
        
        {% if trail.Status == 1 %}
            <input type="hidden" name="update_trail_status" value="0">
            <button type="submit" style="background-color: #d9534f; color: white; border: none; padding: 5px 10px; border-radius: 4px; cursor: pointer;">
                Close Trail
            </button>
        {% else %}
            <input type="hidden" name="update_trail_status" value="1">
            <button type="submit" style="background-color: #5cb85c; color: white; border: none; padding: 5px 10px; border-radius: 4px; cursor: pointer;">
                Open Trail
            </button>
        {% endif %}
    </form>
</td>
            </form>
        </tr>
        {% endfor %}
    </tbody>
</table>

<h2>Create a Trail</h2>
<form class="cuForm" id="create_trail_form" method="POST" action="/trails/create">

    <label for="create_trail_name"> Name: </label>
    <input type="text" name="create_trail_name" id="create_trail_name" required>

    <label for="create_trail_difficulty"> Difficulty: </label>
    <select name="create_trail_difficulty" id="create_trail_difficulty" required>
        <option value="" disabled selected>Select ability level</option>
        <option value="Blue">Blue</option>
        <option value="Green">Green</option>
        <option value="Black">Black</option>
    </select>

    <label for="create_trail_trailLength"> TrailLength: </label>
    <input type="text" name="create_trail_trailLength" id="create_trail_trailLength" required>

    <label for="create_trail_status"> Status: </label>
    <input type="text" name="create_trail_status" id="create_trail_status" required>
    
    </select>

    <input type="submit">
</form>


{% endblock %}