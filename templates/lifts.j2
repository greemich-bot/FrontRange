{# template adapted from starter code, and button styling and logic was modified using gemini #}
{% extends "main.j2" %}
{% block content %}

<h1>Lifts</h1>

{# READ table #}
<table>
    <thead>
        {# For the table header row, we print the DB attribute names #}
        <tr>
            <th>LiftID</th>
            <th>Lift Number</th>
            <th>Lift Name</th>
            <th>Travel Time</th>
            <th>Chair Capacity</th>
            <th>Status</th>
            <th>Altitude</th>
            <th>Delete Lift</th>
            <th>Update Lift Status</th>
        </tr>
    </thead>

    <tbody>
        {# For each row, print the id, fname, lname, homeworld and age #}
        {% for lift in lifts %}
        <tr>
            <td>{{ lift.LiftID }}</td>
            <td>{{ lift.LiftNum }}</td>
            <td>{{ lift.LiftName }}</td>
            <td>{{ lift.TravelTime}}</td>
            <td>{{ lift.ChairCapacity }}</td>
            <td>{% if lift.Status == 1 %}
        <span style="color: #28a745; font-weight: bold;">Open</span>
    {% else %}
        <span style="color: #d9534f; font-weight: bold;">Closed</span>
    {% endif %}</td>
            <td>{{ lift.Altitude }}</td>
            

            {# DELETE form #}
            <td>
            <form class="cuForm" id="delete_lift_form_{{ lift.LiftID }}" method="POST" action="/lifts/delete">
                <input type="hidden" name="delete_lift_id" value="{{ lift.LiftID }}">
                    <input type="submit" value="Delete" onclick="return confirm('Are you sure you want to delete this lift: {{ lift.LiftName }}? All assosciated lift rides will also be deleted.')">
                </form>
                </td>


            {# UPDATE form #}
         <td>
    <form method="POST" action="/lifts/update">
        <input type="hidden" name="update_lift_id" value="{{ lift.LiftID }}">
        
        {# If status is 1 (Open), send 0 (Close) #}
        {% if lift.Status == 1 %}
            <input type="hidden" name="update_lift_status" value="0">
            <button type="submit" style="background-color: #d9534f; color: white; border: none; padding: 5px 10px; border-radius: 4px; cursor: pointer;">
                Close Lift
            </button>
        {# If status is 0 (Closed), send 1 (Open) #}
        {% else %}
            <input type="hidden" name="update_lift_status" value="1">
            <button type="submit" style="background-color: #5cb85c; color: white; border: none; padding: 5px 10px; border-radius: 4px; cursor: pointer;">
                Open Lift
            </button>
        {% endif %}
    </form>
</td>



        </tr>
        {% endfor %}
    </tbody>
</table>


{% endblock %}
<script>
function toggleUpdateForm(liftID) {
    var form = document.getElementById('update_form_' + liftID);
    if (form.style.display === "none") {
        form.style.display = "block";
    } else {
        form.style.display = "none";
    }
}
</script>
