{% extends "main.j2" %}
{% block content %}

<h1>Passes</h1>

{# READ table #}
<table>
    <thead>
        {# For the table header row, we print the DB attribute names #}
        <tr>
            {% for key in passes[0].keys() %}
            <th>{{ key }}</th>
            {% endfor %}
            <th></th>
        </tr>
    </thead>

    <tbody>
        {# For each row, print the id, fname, lname, homeworld and age #}
        {% for pass in passes %}
        <tr>
            <td>{{ pass.PassID }}</td>
            <td>{{ pass.Type}}</td>
            <td>{{ pass.PurchaseDate }}</td>
            <td>{{ pass.ExpirationDate }}</td>
            <td>{{ pass.Skiers_SkierID }}</td>
            

            {# DELETE form #}
            <form id="delete_pass_form">
                <input type="hidden" name="delete_pass_id" value="{{ pass.PassID }}">
                <input type="hidden" name="delete_pass_name" value="{{ pass.Type }}">
                <td>
                    <button type="submit">
                        Delete
                    </button>
                </td>
            </form>
            <form id="update_pass_form">
                <input type="hidden" name="update_pass_id" value="{{ pass.PassID }}">
                <input type="hidden" name="update_pass_type" value="{{ pass.Type }}"> 
                <input type="hidden" name="update_pass_purchase_date" value="{{ pass.PurchaseDate }}">
                <input type="hidden" name="update_pass_expiration_date" value="{{ pass.ExpirationDate }}">
                <input type="hidden" name="update_pass_skier_id" value="{{ pass.Skiers_SkierID }}">
                <td>
                    <button type="submit">
                        Update
                    </button>
                </td>
            </form>
        </tr>
        {% endfor %}
    </tbody>
</table>

<h2>Create Passes</h2>


<form class="cuForm" id="create_passes_form" method="POST" action="/passes/create">

<label>Type:</label>
<select name="create_pass_type" required>
    <option disabled selected>Select pass type</option>
    <option value="Full Season">Full Season</option>
    <option value="Day Pass">Day Pass</option>
    <option value="3-Day Pass">3-Day Pass</option>
</select>

<label>Purchase Date:</label>
<input type="datetime-local"
       name="create_purchase_date"
       required>

<label>Expiration Date:</label>
<input type="datetime-local"
       name="create_expiration_date"
       required>

<label>Skier:</label>
<select name="create_skier_skierId" required>

    <option value="" disabled selected>
        Select Skier
    </option>

    {% for skier in skiers %}
        <option value="{{ skier.SkierID }}">
            {{ skier.Name }}
        </option>
    {% endfor %}

</select>

<input type="submit">

</form>

{% endblock %}