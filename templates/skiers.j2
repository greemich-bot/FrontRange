{# adapted from starter code. Edit skier hide functionality and styling was copied from gemini output#}
{% extends "main.j2" %}
{% block content %}

<h1>Skiers</h1>

{# READ table #}
<table>
    <thead>
        {# For the table header row, we print the DB attribute names #}
        <tr>
            {% for key in skiers[0].keys() %}
            <th>{{ key }}</th>
            {% endfor %}
            <th>Delete Skier</th>
            <th>Edit Skier</th>
        </tr>
    </thead>

    <tbody>
        {# For each row, print the kier attributes #}
        {% for skier in skiers %}
        <tr>
            <td>{{ skier.SkierID }}</td>
            <td>{{ skier.Name}}</td>
            <td>{{ skier.Address }}</td>
            <td>{{ skier.Phone }}</td>
            <td>{{ skier.Email }}</td>
            <td>{{ skier.Ability }}</td>

            {# DELETE form #}
            <td>
                <form class="cuForm" id="delete_skier_form_{{ skier.SkierID }}" method="POST" action="/skiers/delete">
                    <input type="hidden" name="delete_skier_id" value="{{ skier.SkierID }}">
                    <input type="submit" value="Delete">
                </form>
            </td>
            {# UPDATE form #}
            <td>
        <!-- 1. The Trigger Button -->
        <button type="button" onclick="toggleUpdateForm('{{ skier.SkierID }}')">Edit</button>

        <!-- 2. The Hidden Form -->
        <form class="cuForm" id="update_form_{{ skier.SkierID }}" 
      method="POST" action="/skiers/update" 
      style="display:none; margin-top: 10px; border: 1px solid #ccc; padding: 15px; width: 300px;">
    
    <input type="hidden" name="update_skier_id" value="{{ skier.SkierID }}">
    
    <div style="margin-bottom: 10px;">
        <label style="display: block; font-weight: bold;">Name:</label>
        <input type="text" name="update_skier_name" value="{{ skier.Name }}" required style="width: 100%;">
    </div>

    <div style="margin-bottom: 10px;">
        <label style="display: block; font-weight: bold;">Email:</label>
        <input type="email" name="update_skier_email" value="{{ skier.Email }}" required style="width: 100%;">
    </div>

    <div style="margin-bottom: 10px;">
        <label style="display: block; font-weight: bold;">Address:</label>
        <input type="text" name="update_skier_address" value="{{ skier.Address }}" required style="width: 100%;">
    </div>

    <div style="margin-bottom: 10px;">
        <label style="display: block; font-weight: bold;">Phone:</label>
        <input type="text" name="update_skier_phone" value="{{ skier.Phone }}" required style="width: 100%;">
    </div>

    <div style="margin-bottom: 10px;">
        <label style="display: block; font-weight: bold;">Ability:</label>
        <select name="update_skier_ability" required style="width: 100%;">
            <option value="Beginner" {% if skier.Ability == 'Beginner' %}selected{% endif %}>Beginner</option>
            <option value="Intermediate" {% if skier.Ability == 'Intermediate' %}selected{% endif %}>Intermediate</option>
            <option value="Expert" {% if skier.Ability == 'Expert' %}selected{% endif %}>Expert</option>
        </select>
    </div>
    
    <div style="margin-top: 15px; display: flex; gap: 10px;">
        <input type="submit" value="Save Changes">
        <button type="button" onclick="toggleUpdateForm('{{ skier.SkierID }}')">Cancel</button>
    </div>
</form>

</form>
    </td>       
        </tr>
        {% endfor %}
    </tbody>
</table>

<h2>Create a Skier</h2>
<form class="cuForm" id="create_skier_form" method="POST" action="/skiers/create">

    <label for="create_skier_name"> Name: </label>
    <input type="text" name="create_skier_name" id="create_skier_name" required>

    <label for="create_skier_address"> Address: </label>
    <input type="text" name="create_skier_address" id="create_skier_address" required>

    <label for="create_skier_phone"> Phone: </label>
    <input type="text" name="create_skier_phone" id="create_skier_phone" required>
    <label for="create_skier_email"> Email: </label>
    <input type="email" name="create_skier_email" id="create_skier_email" required>
    <label for="create_skier_ability"> Ability: </label>
    <select name="create_skier_ability" id="create_skier_ability" required>
        <option value="" disabled selected>Select ability</option>
        <option value="Beginner">Beginner</option>
        <option value="Intermediate">Intermediate</option>
        <option value="Expert">Expert</option>
    </select>

    <input type="submit">
</form>

{% endblock %}